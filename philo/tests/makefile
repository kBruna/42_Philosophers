# ==========================================================
#  Shellyrox-Tester — universal C unit-test framework
#
#  Do NOT edit this file to port the framework to another
#  project: every project-specific setting lives in config.mk.
# ==========================================================

# Defaults — override them in config.mk if needed
CC      = cc
CFLAGS  = -g3 -Wall -Wextra -Werror

include config.mk

TEST_DIR        = .
FRAMEWORK_SRCS  = $(TEST_DIR)/utils/capture_stdout.c \
                  $(TEST_DIR)/utils/test_log.c

# Test files are auto-discovered: any test-*.c in this folder
TEST_SRCS   = $(wildcard $(TEST_DIR)/test-*.c)
TEST_BINS   = $(TEST_SRCS:.c=.out)
REPORT_LOG  = test_report.log

HEADERS     = -I$(TEST_DIR) $(PROJECT_INCLUDES)

# The report is a single shared file: parallel jobs (-j) would interleave
# compiler output and detach results from their "File:" headers.
.NOTPARALLEL:

# Main test target: builds and runs every test file independently,
# writes the report, then exits 0 only if everything passed (CI-friendly).
# Note: on failure GNU make itself reports exit status 2 — check for
# non-zero in CI, not for a specific code.
test:
	@rm -f $(REPORT_LOG)
	@printf "TEST REPORT - %s\n" "$$(date)" > $(REPORT_LOG)
	@printf -- "------------------------------------------\n" >> $(REPORT_LOG)
	@# Dependency libs come first; a broken dep fails fast and honestly
	@if ! $(MAKE) deps --no-print-directory; then \
		printf "\n      [ERROR] Dependency build failed\n" >> $(REPORT_LOG); \
		cat $(REPORT_LOG); \
		printf "\n\033[0;31m[!] Dependency build failed.\033[0m\n"; \
		exit 1; \
	fi
ifeq ($(strip $(TEST_SRCS)),)
	@printf "\n[!] No test-*.c files found in $(TEST_DIR)\n" >> $(REPORT_LOG); \
	cat $(REPORT_LOG); \
	printf "\n\033[0;31m[!] No tests were run.\033[0m\n"; \
	exit 1
endif
	@# Run binaries ignoring errors so the job keeps running
	-@$(MAKE) run_test_bins --no-print-directory
	@# Final summary. Counts are anchored to the exact line formats the
	@# framework emits (6-space indent), so "[PASS]"/"Case:" appearing
	@# inside assert messages or compiler output can never inflate them.
	@PASSED=$$(grep -c "^      \[PASS\] Case:" $(REPORT_LOG)); \
	FAILS=$$(grep -c "^      \[FAIL\] Case:" $(REPORT_LOG)); \
	ERRORS=$$(grep -c "^      \[ERROR\]" $(REPORT_LOG)); \
	TOTAL=$$((PASSED + FAILS)); \
	{ \
		printf "\n"; \
		printf "==========================================\n"; \
		printf "📊 Summary:\n"; \
		printf "  Total cases:  %s\n" "$$TOTAL"; \
		printf "  ✅ Pass:      %s\n" "$$PASSED"; \
		printf "  ❌ Fail:      %s\n" "$$FAILS"; \
		printf "  ⚠️  Errors:    %s\n" "$$ERRORS"; \
		printf "==========================================\n"; \
	} >> $(REPORT_LOG); \
	cat $(REPORT_LOG); \
	if [ "$$FAILS" -gt 0 ] || [ "$$ERRORS" -gt 0 ]; then \
		printf "\n\033[0;31m[!] Test suite failed.\033[0m\n"; \
		exit 1; \
	else \
		printf "\n\033[0;32m[+] Test suite passed successfully.\033[0m\n"; \
	fi

# Builds dependency libraries (libft-style) before the tests, if any
deps:
ifneq ($(strip $(DEP_LIB_DIRS)),)
	@for dir in $(DEP_LIB_DIRS); do \
		$(MAKE) -C $$dir --no-print-directory || exit 1; \
	done
else
	@true
endif

run_test_bins: $(TEST_BINS)

# Per-file compile-and-run rule.
# Compilation failure  -> [ERROR] in the report (compiler output included)
# Runtime crash        -> [ERROR] in the report (exit code included)
# SHELLYROX_REPORT=1 routes the binary's results into the report file;
# without it (manual run / gdb) results go to stderr instead.
$(TEST_DIR)/%.out: $(TEST_DIR)/%.c
	@printf "\nFile: $<\n" >> $(REPORT_LOG)
	@if $(CC) $(CFLAGS) $(PROJECT_SRCS) $(FRAMEWORK_SRCS) $< $(HEADERS) \
		$(PROJECT_LIBS) -o $@ >> $(REPORT_LOG) 2>&1; then \
		SHELLYROX_REPORT=1 ./$@; STATUS=$$?; \
		if [ $$STATUS -ne 0 ]; then \
			printf "      [ERROR] Runtime failure (exit code %d)\n" \
				"$$STATUS" >> $(REPORT_LOG); \
		fi; \
		rm -f $@; \
	else \
		printf "      [ERROR] Compilation failed\n" >> $(REPORT_LOG); \
	fi

# Builds one test binary (kept on disk) for debugging with gdb/valgrind:
#   make single T=parser   ->  compiles test-parser.c into unit_test.out
# Run it directly and the results print to stderr (not the report file).
single: deps
ifndef T
	$(error Usage: make single T=<name>  (compiles test-<name>.c into unit_test.out))
endif
	@echo "Compiling individual test binary for: test-$(T).c"
	$(CC) $(CFLAGS) $(PROJECT_SRCS) $(FRAMEWORK_SRCS) test-$(T).c $(HEADERS) \
		$(PROJECT_LIBS) -o unit_test.out

# Cleaning only touches the framework's own artifacts —
# dependency libs are the parent project's responsibility.
clean:
	rm -f $(TEST_DIR)/*.out

fclean: clean
	rm -f $(REPORT_LOG)

.PHONY: test deps run_test_bins single clean fclean
